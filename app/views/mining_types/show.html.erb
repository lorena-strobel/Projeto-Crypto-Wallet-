<p id="notice"><%= notice %></p>
<form class="p-3">
  <div class="mb-3">
    <%= label_tag :description, @mining_type.class.human_attribute_name(:description), class: "form-label" %>
    <%= text_field_tag :description, @mining_type.description, class: "form-control", disabled: true%>
  </div>

  <div class="mb-3">
    <%= label_tag :acronym, @mining_type.class.human_attribute_name(:acronym), class: "form-label" %>
    <%= text_field_tag :acronym, @mining_type.acronym, class: "form-control", disabled: true %>
  </div>
</form>

<%= link_to t('links.edit'), edit_mining_type_path(@mining_type), class:"btn btn-primary" %> |
<%= link_to t('links.back'), mining_types_path, class: "btn btn-primary" %>
