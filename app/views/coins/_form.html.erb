<%= form_for(coin) do |f| %>
  <% if coin.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(coin.errors.count, "error") %> prohibited this coin from being saved:</h2>

      <ul>
      <% coin.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :description %>
    <%= f.text_field :description, class:"form-control", placeholder:"Bitcoin" %>
  </div>

  <div class="mb-3">
    <%= f.label :acronym %>
    <%= f.text_field :acronym, class:"form-control", placeholder:"BTC" %>
  </div>

  <div class="mb-3">
    <%= f.label :url_image %>
    <%= f.text_field :url_image, class:"form-control", placeholder:"http://img.ur/bitcoin.png" %>
    <%#= image_tag coin.url_image, width:25, height:25 %> 
  </div>

  <div class="mb-3">
    <%= f.label :mining_type_id %>
    <%= f.select("mining_type_id", MiningType.all.pluck(:description, :id), {include_blank: 'Selecione...'}, class:"form-control")%>
  </div>

  <div class="actions">
    <%= f.submit nil, class:"btn btn-primary" %>
  </div>
<% end %>
</br>